super + Escape
	pkill -USR1 -x sxhkd

super + Return
    alacritty

super + w
    firefox

super + e
    thunar

super + space
    rofi -show drun


super + p
	colorpicker

XF86MonBrightness{Up,Down}
	brightness{ --inc, --dec}
	
# Speaker Volume control
XF86Audio{RaiseVolume,LowerVolume}
	volume{ --inc, --dec}

# Mic Volume control
XF86Audio{Mute,MicMute}
	volume{ --toggle, --toggle-mic}
	
# Music control
XF86Audio{Next,Prev,Play,Stop}
	mpc {next,prev,toggle,stop}

